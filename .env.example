# ── QFIS Configuration ─────────────────────────────────────────
# Copy this to .env and adjust before running docker compose up

# Port to expose (default: 8080)
PORT=8080

# API Key — set to enable authentication via X-API-Key header
# Leave empty for open access (development only)
API_KEY=

# Allowed CORS origins (comma-separated, default: *)
CORS_ORIGINS=*

# Path to SQLite database (inside container: /app/data/qfis.db)
# QFIS_DB_PATH=/app/data/qfis.db
